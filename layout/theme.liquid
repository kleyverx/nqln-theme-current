      var sidebar = document.querySelector('.page-sidebar');
      if (sidebar && sidebar.parentElement !== document.body) {
        document.body.appendChild(sidebar);
      }
    })();
    </script>
    <script>
    /* Product card video: desktop=hover, mobile=tap to play (scroll-aware) */
    (function () {
      var isMobile = window.innerWidth < 1025;

      if (!isMobile) {
        document.addEventListener('mouseenter', function (e) {
          var card = e.target.closest('.card-media.media--hover-effect');
          if (!card) return;
          var video = card.querySelector('video');
          if (video) video.play();
        }, true);
        document.addEventListener('mouseleave', function (e) {
          var card = e.target.closest('.card-media.media--hover-effect');
          if (!card) return;
          var video = card.querySelector('video');
          if (video) { video.pause(); video.currentTime = 0; }
        }, true);
      } else {
        var activeCard = null;
        var touchStartY = 0;
        var didScroll = false;

        document.addEventListener('touchstart', function (e) {
          touchStartY = e.touches[0].clientY;
          didScroll = false;
        }, { passive: true });

        document.addEventListener('touchmove', function () {
          didScroll = true;
        }, { passive: true });

        document.addEventListener('click', function (e) {
          if (didScroll) return;
          var card = e.target.closest('.card-media.media--hover-effect');
          if (!card) {
            if (activeCard) {
              var v = activeCard.querySelector('video');
              if (v) { v.pause(); v.currentTime = 0; }
              activeCard.classList.remove('video-playing');
              activeCard = null;
            }
            return;
          }
          var video = card.querySelector('video');
          if (!video) return;
          if (card === activeCard) return;
          e.preventDefault();
          e.stopPropagation();
          if (activeCard && activeCard !== card) {
            var prev = activeCard.querySelector('video');
            if (prev) { prev.pause(); prev.currentTime = 0; }
            activeCard.classList.remove('video-playing');
          }
          card.classList.add('video-playing');
          video.play();
          activeCard = card;
        }, true);
      }
    })();
    </script>

    <script>
    (function() {
      var translate = function(root) {
        var nodes = (root || document).querySelectorAll('select option');
        for (var i = 0; i < nodes.length; i++) {
          var t = nodes[i].textContent;
          if (t.indexOf('Sold out') !== -1 || t.indexOf('sold out') !== -1) {
            nodes[i].textContent = t.replace(/sold out/gi, 'Agotado');
          }
          if (t.indexOf('Unavailable') !== -1) {
            nodes[i].textContent = nodes[i].textContent.replace(/Unavailable/g, 'No disponible');
          }
        }
      };
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function() { translate(); });
      } else {
        translate();
      }
      var obs = new MutationObserver(function(muts) {
        for (var i = 0; i < muts.length; i++) {
          for (var j = 0; j < muts[i].addedNodes.length; j++) {
            var n = muts[i].addedNodes[j];
            if (n.nodeType === 1) translate(n);
          }
          if (muts[i].target && muts[i].target.tagName === 'OPTION') translate(muts[i].target.parentNode);
        }
      });
      obs.observe(document.documentElement, { childList: true, subtree: true, characterData: true });
    })();
    </script>
  </body>
</html>

  
