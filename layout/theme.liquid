        z-index: 2147483647 !important;
        width: 0;
        visibility: hidden;
        background-image: none !important;
        box-shadow: none !important;
        filter: none !important;
        border: 0 !important;
        outline: none !important;
        transition: width 0.3s cubic-bezier(0.1, 0.05, 0.4, 1);
