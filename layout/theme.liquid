    {%- comment -%} View Transitions API for page navigation (mobile only) {%- endcomment -%}
    {%- comment -%} Note: <meta name="view-transition"> is obsolete. The CSS @view-transition rule below is all that's needed. {%- endcomment -%}
    <style>
      @media (max-width: 1024px) {
        @view-transition {
          navigation: auto;
        }

        /* Kill ALL root animation - no flash, no fade, nothing */
        ::view-transition-old(root),
        ::view-transition-new(root) {
          animation: none !important;
          mix-blend-mode: normal !important;
        }

        /* Stack old and new on top of each other */
        ::view-transition-group(root) {
          animation-duration: 0s !important;
        }

        /* Header: frozen in place */
        .section-header-single-line,
        .section-header-mobile,
        .section-header-navigation-vertical-menu {
          view-transition-name: header;
        }

        ::view-transition-old(header),
        ::view-transition-new(header) {
          animation: none;
        }

        /* Toolbar mobile: frozen in place */
        .halo-sticky-toolbar-mobile {
          view-transition-name: toolbar;
        }

        ::view-transition-old(toolbar),
        ::view-transition-new(toolbar) {
          animation: none;
        }

        /* Marquee: frozen */
        .section-marquee {
          view-transition-name: marquee;
        }

        ::view-transition-old(marquee),
        ::view-transition-new(marquee) {
          animation: none;
        }

        /* Custom header banner (categories + info): frozen */
        .custom-header-banner {
          view-transition-name: header-banner;
        }

        ::view-transition-old(header-banner),
        ::view-transition-new(header-banner) {
          animation: none;
        }

        /* ONLY main content animates */
        .content-for-layout {
          view-transition-name: main-content;
        }

        ::view-transition-old(main-content) {
          animation: vt-out 0.15s ease-out forwards;
        }

        ::view-transition-new(main-content) {
          animation: vt-in 0.15s ease-out forwards;
        }

        @keyframes vt-out {
          from { opacity: 1; }
          to { opacity: 0; }
        }

        @keyframes vt-in {
          from { opacity: 0; }
          to { opacity: 1; }
        }
      }
    </style>
