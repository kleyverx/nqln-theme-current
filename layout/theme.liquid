    <script>
    /* Wishlist count badge: hide bubble when count is 0 or empty */
    (function () {
      function update() {
        document.querySelectorAll('.wishlist-count-bubble').forEach(function (b) {
          var t = b.querySelector('[data-wishlist-count]');
          b.style.display = (!t || !t.textContent || t.textContent === '0') ? 'none' : '';
        });
      }
      function observe() {
        update();
        document.querySelectorAll('[data-wishlist-count]').forEach(function (el) {
          if (el._wlOb) return;
          el._wlOb = true;
          new MutationObserver(update).observe(el, { childList: true, characterData: true, subtree: true });
        });
      }
      observe();
      document.addEventListener('DOMContentLoaded', observe);
    })();
    </script>
    <script>
    (function () {
