<div class="alireviews-stars-wrapper">
  <div product-id="{{ product.id }}" product-handle="{{ product.handle }}" class="alireviews-review-star-rating"></div>
</div>
{% comment %}
  Renders a list of product's price (regular, sale)

  Accepts:
  - product: {Object} Product Liquid object (optional)
  - use_variant: {Boolean} Renders selected or first variant price instead of overall product pricing (optional)
  - show_badges: {Boolean} Renders 'Sale' and 'Sold Out' tags if the product matches the condition (optional)
  - price_class: {String} Adds a price class to the price element (optional)

  Usage:
  {% render 'price', product: product %}
{% endcomment %}
{%- liquid
  if use_variant
    assign target = product.selected_or_first_available_variant
  else
    assign target = product
  endif

  assign compare_at_price = target.compare_at_price
  assign price = target.price | default: 1999
  assign available = target.available | default: false
  assign money_price = price | money

  if target == product and product.price_varies
    assign money_price = 'products.product.price.from_price_html' | t: price: money_price
  endif

  assign collection_discount = 0
  assign has_collection_discount = false
  assign fecha_fin_desc = blank

  for col in product.collections
    if col.metafields.custom.descuento_porcentaje != blank
      assign collection_discount = col.metafields.custom.descuento_porcentaje | plus: 0
      if collection_discount > 0
        assign has_collection_discount = true
        break
      endif
    endif
  endfor

  for col in product.collections
    if col.metafields.custom.fecha_fin_desc != blank
      assign fecha_fin_desc = col.metafields.custom.fecha_fin_desc
      break
    endif
  endfor

  if has_collection_discount and compare_at_price == blank or has_collection_discount and compare_at_price <= price
    assign original_price = price | times: 100 | divided_by: 100 | minus: 0
    assign discount_multiplier_num = 100 | minus: collection_discount
    assign discounted_price = original_price | times: discount_multiplier_num | divided_by: 100
    assign compare_at_price = original_price
    assign price = discounted_price
    assign money_price = price | money
  endif
-%}

<div
  class="
    price
    {%- if price_class %} {{ price_class }}{% endif -%}
    {%- if available == false %} price--sold-out {% endif -%}
    {%- if compare_at_price > price %} price--on-sale {% endif -%}
    {%- if product.price_varies == false and product.compare_at_price_varies %} price--no-compare{% endif -%}
  "
>
  <dl>
    <div class="price__regular">
      <dd class="price__last">
        <span class="price-item price-item--regular">{{ money_price }}</span>
      </dd>
    </div>
    <div class="price__sale">
      {%- comment -%} Sale price first (big, bold) {%- endcomment -%}
      <dd class="price__last">
        <span class="price-item price-item--sale">{{ money_price }}</span>
      </dd>
      {%- comment -%} Original price strikethrough (red) {%- endcomment -%}
      <dd class="price__compare">
        <s class="price-item price-item--regular">{{ compare_at_price | money }}</s>
      </dd>
      {%- comment -%} Ahorro badge {%- endcomment -%}
      {%- if compare_at_price > price -%}
        {% assign saved_price = compare_at_price | minus: price | money %}
        <dd class="price__saved-inline">
          <span class="price-item price-item--saved">Ahorro de {{ saved_price }}</span>
        </dd>
      {%- endif -%}
      {%- comment -%} Discount % label {%- endcomment -%}
      {%- if compare_at_price > price -%}
        <dd class="price__label_sale">
          {%- if has_collection_discount -%}
            <span class="label_sale">-{{ collection_discount }}%</span>
          {%- else -%}
            {% liquid
              assign list_compare = product.variants | where: 'compare_at_price'
              assign compare = 0
              for variant in list_compare
                assign saving = variant.compare_at_price | minus: variant.price | times: 100.0 | divided_by: variant.compare_at_price | round
                if saving > compare
                  assign compare = saving
                endif
              endfor
              if compare < 1
                assign compare = product.compare_at_price_min | minus: product.price_min | times: 100.0 | divided_by: product.compare_at_price_min | round
              endif
            -%}
            <span class="label_sale">-{{ compare | append: '%' }}</span>
          {%- endif -%}
        </dd>
      {%- endif -%}
      {%- comment -%} Countdown timer — solo en página de producto {%- endcomment -%}
      {%- if request.page_type == 'product' and fecha_fin_desc != blank and compare_at_price > price -%}
        <div class="price__countdown-offer">
          <span class="price__countdown-icon">⏰</span>
          <span class="price__countdown-text">¡Aprovecha! Oferta termina en:</span>
          <span class="price__countdown-timer" data-countdown-end="{{ fecha_fin_desc }}"></span>
        </div>
        <script>
          /* Countdown global — se auto-inicializa */
          (function () {
            if (window.__countdownInitialized) return;
            window.__countdownInitialized = true;

            function initCountdowns() {
              var els = document.querySelectorAll('[data-countdown-end]:not([data-countdown-active])');
              els.forEach(function (el) {
                el.setAttribute('data-countdown-active', 'true');
                var rawDate = el.getAttribute('data-countdown-end');
                var endDate = new Date(rawDate).getTime();
                if (isNaN(endDate)) endDate = new Date(rawDate + 'T23:59:59').getTime();
                if (isNaN(endDate)) {
                  el.closest('.price__countdown-offer').style.display = 'none';
                  return;
                }

                function tick() {
                  var diff = endDate - Date.now();
                  if (diff <= 0) {
                    el.textContent = '¡Oferta finalizada!';
                    return;
                  }
                  var d = Math.floor(diff / 86400000);
                  var h = Math.floor((diff % 86400000) / 3600000);
                  var m = Math.floor((diff % 3600000) / 60000);
                  var s = Math.floor((diff % 60000) / 1000);
                  var p = [];
                  if (d > 0) p.push(d + 'd');
                  p.push(h + 'h', m + 'm', s + 's');
                  el.textContent = p.join(' ');
                  requestAnimationFrame(function () {
                    setTimeout(tick, 1000);
                  });
                }
                tick();
              });
            }

            /* Inicializar ahora */
            initCountdowns();

            /* Re-inicializar cuando Shopify actualice secciones */
            document.addEventListener('shopify:section:load', initCountdowns);

            /* Observer para cambios AJAX */
            var observer = new MutationObserver(function () {
              var pending = document.querySelectorAll('[data-countdown-end]:not([data-countdown-active])');
              if (pending.length > 0) initCountdowns();
            });
            observer.observe(document.body, { childList: true, subtree: true });
          })();
        </script>
      {%- endif -%}
    </div>
    {%- comment -%} Badges dinámicos por Tags (ocultado por CSS en página de producto) {%- endcomment -%}
    <dd class="price__free-shipping">
      {%- liquid
        assign highlight_tag = blank
        assign badge_class = blank
        assign badge_text = blank
        assign badge_icon = blank

        for tag in product.tags
          assign tag_down = tag | downcase
          if tag_down contains 'tendencia'
            assign highlight_tag = 'trend'
            assign badge_class = 'price-item--tag-trend'
            assign badge_text = settings.badge_trend_text
            assign badge_icon = settings.badge_trend_icon
            break
          elsif tag_down contains 'nuevo'
            assign highlight_tag = 'new'
            assign badge_class = 'price-item--tag-new'
            assign badge_text = settings.badge_new_text
            assign badge_icon = settings.badge_new_icon
            break
          elsif tag_down contains 'semana'
            assign highlight_tag = 'weekly'
            assign badge_class = 'price-item--tag-weekly'
            assign badge_text = settings.badge_weekly_text
            assign badge_icon = settings.badge_weekly_icon
            break
          elsif tag_down contains 'mes'
            assign highlight_tag = 'monthly'
            assign badge_class = 'price-item--tag-monthly'
            assign badge_text = settings.badge_monthly_text
            assign badge_icon = settings.badge_monthly_icon
            break
          endif
        endfor
      -%}

      {%- if highlight_tag != blank -%}
        <span class="price-item--tag-badge {{ badge_class }}">
          {%- if badge_icon != blank -%}<span class="badge-icon">{{ badge_icon }}</span>{%- endif -%}
          <span class="badge-label">{{ badge_text }}</span>
        </span>
      {%- endif -%}
    </dd>
    <small class="unit-price caption{% if available == false or product.selected_or_first_available_variant.unit_price_measurement == nil %} hidden{% endif %}">
      <dt class="visually-hidden">{{ 'products.product.price.unit_price' | t }}</dt>
      <dd class="price__last">
        <span>{{- product.selected_or_first_available_variant.unit_price | money -}}</span
        ><span aria-hidden="true">/</span
        ><span class="visually-hidden">&nbsp;{{ 'accessibility.unit_price_separator' | t }}&nbsp;</span
        ><span>
          {%- if product.selected_or_first_available_variant.unit_price_measurement.reference_value != 1 -%}
            {{- product.selected_or_first_available_variant.unit_price_measurement.reference_value -}}
          {%- endif -%}
          {{ product.selected_or_first_available_variant.unit_price_measurement.reference_unit -}}
        </span>
      </dd>
    </small>
  </dl>
</div>
