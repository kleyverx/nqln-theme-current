<div class="halo-popup halo-search-popup" data-search-popup id="halo-search-popup">
    <div class="halo-popup-wrapper">
    	<div class="halo-popup-header customPopup-header">
            <div class="container">
    		    <button type="button" class="halo-sidebar-popup" data-search-close-popup aria-label="{{ 'general.common.close' | t }}">
                    {% render 'icon-close' %}
                </button>
            </div>
    	</div>
	    <div class="halo-popup-content custom-scrollbar">
            <div class="container">
                <style>
                    .halo-search-popup predictive-search { position: static; }
                    .halo-search-popup #predictive-search,
                    .halo-search-popup #predictive-search-trending {
                        position: static;
                        width: 100%;
                        min-width: unset;
                        max-width: 100%;
                        box-shadow: none;
                        border-radius: 0;
                        margin-top: 12px;
                    }
                    .halo-search-popup .predictive-search-form__input {
                        padding: 12px 50px 12px 18px;
                        font-size: 16px;
                    }
                </style>
                {% render 'predictive-search-form' %}
            </div>
	    </div>
    </div>
</div>
