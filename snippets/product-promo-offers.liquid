{%- liquid
  assign uid = block.id | default: section.id | default: 'promo'
  assign promo_image = blank
  assign promo_link = blank

  for col in product.collections
    if col.metafields.custom.promo_imagen_banner != blank
      assign promo_image = col.metafields.custom.promo_imagen_banner.value
      assign promo_link = col.metafields.custom.promo_link_banner.value
      break
    endif
  endfor
-%}

{%- if promo_image != blank -%}
  <div id="promo-{{ uid }}" class="promo-offer-wrap">
    {%- if promo_link != blank -%}
      <a href="{{ promo_link }}" class="promo-offer-link" rel="noopener nofollow">
    {%- endif -%}

    <div class="promo-offer-inner">
      <img
        src="{{ promo_image | image_url: width: 1400 }}"
        srcset="
          {{ promo_image | image_url: width: 700 }}  700w,
          {{ promo_image | image_url: width: 1050 }} 1050w,
          {{ promo_image | image_url: width: 1400 }} 1400w
        "
        sizes="(min-width: 750px) 700px, 100vw"
        alt="{{ promo_image.alt | escape | default: 'Promoción especial' }}"
        class="promo-offer-img"
        width="{{ promo_image.width }}"
        height="{{ promo_image.height }}"
        loading="lazy"
        decoding="async"
      >
    </div>

    {%- if promo_link != blank -%}
      </a>
    {%- endif -%}
  </div>

  <style>
    @keyframes promo-gradient-spin {
      0%   { background-position: 0% 50%; }
      50%  { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }

    @keyframes promo-shine-sweep {
      0%   { transform: skewX(-25deg) translateX(-250%); }
      40%  { transform: skewX(-25deg) translateX(500%); }
      100% { transform: skewX(-25deg) translateX(500%); }
    }

    /* Outer wrapper – 2px animated gradient border */
    #promo-{{ uid }}.promo-offer-wrap {
      display: block;
      width: 100%;
      max-width: 350px;
      margin: 20px 0;
      border-radius: 14px;
      padding: 2px;
      background: linear-gradient(90deg, #08c4af, #805ae6, #08c4af);
      background-size: 200% auto;
      animation: promo-gradient-spin 3s linear infinite;
      transition: transform 300ms ease, box-shadow 300ms ease;
    }

    /* Hover: subtle lift + soft teal glow */
    #promo-{{ uid }}.promo-offer-wrap:hover {
      transform: translateY(-4px);
      box-shadow: 0 8px 22px rgba(8, 196, 175, 0.35);
    }

    #promo-{{ uid }} .promo-offer-link {
      display: block;
      text-decoration: none;
    }

    /* Image wrapper – clips the shiny effect */
    #promo-{{ uid }} .promo-offer-inner {
      position: relative;
      overflow: hidden;
      border-radius: 12px;
    }

    #promo-{{ uid }} .promo-offer-img {
      display: block;
      width: 100%;
      height: auto;
      object-fit: cover;
      transition: transform 300ms ease;
    }

    /* Slight zoom on hover */
    #promo-{{ uid }}.promo-offer-wrap:hover .promo-offer-img {
      transform: scale(1.03);
    }

    /* Shiny sweep via ::after */
    #promo-{{ uid }} .promo-offer-inner::after {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      width: 50%;
      height: 100%;
      background: linear-gradient(
        to right,
        rgba(255, 255, 255, 0)   0%,
        rgba(255, 255, 255, 0.6) 50%,
        rgba(255, 255, 255, 0)   100%
      );
      transform: skewX(-25deg) translateX(-250%);
      animation: promo-shine-sweep 3.5s ease-in-out infinite;
      pointer-events: none;
    }
  </style>
{%- endif -%}
