{%- liquid
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign hide_desktop = section.settings.hide_on_desktop
-%}

<style>
  .main-menu-mobile-{{ section.id }} {
    padding-top: {{ padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ padding_bottom | times: 0.75 | round: 0 }}px;
    {% if hide_desktop %}
      display: block;
    {% endif %}
  }

  @media screen and (min-width: 750px) {
    .main-menu-mobile-{{ section.id }} {
      padding-top: {{ padding_top }}px;
      padding-bottom: {{ padding_bottom }}px;
      {% if hide_desktop %}
        display: none;
      {% endif %}
    }
  }

  .main-menu-mobile__container {
    max-width: var(--container-width, 1200px);
    margin: 0 auto;
    padding: 0 15px;
  }

  .main-menu-mobile__list {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  .main-menu-mobile__item {
    position: relative;
    display: block;
    width: 100%;
    border-radius: 16px;
    overflow: hidden;
    text-decoration: none;
    background-color: #f3f3f3;
    aspect-ratio: 2.2 / 1;
    transition: transform 0.2s ease;
  }

  .main-menu-mobile__item:active {
    transform: scale(0.98);
  }

  .main-menu-mobile__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .main-menu-mobile__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #e0e0e0;
    color: #999;
  }

  .main-menu-mobile__overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    background: rgba(255, 255, 255, 0.75);
    backdrop-filter: blur(5px);
    -webkit-backdrop-filter: blur(5px);
    padding: 8px 16px;
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 6px;
  }

  .main-menu-mobile__text {
    color: #1a1a1a;
    font-size: 16px;
    font-weight: 900;
    letter-spacing: 0.03em;
    margin: 0;
  }

  .main-menu-mobile__icon {
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #000000;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .main-menu-mobile__item:hover .main-menu-mobile__icon,
  .main-menu-mobile__item:active .main-menu-mobile__icon {
    transform: translateX(4px);
  }

  .main-menu-mobile__icon svg {
    width: 100%;
    height: 100%;
    fill: none;
    stroke: currentColor;
    stroke-width: 2.5;
  }
</style>

<div class="main-menu-mobile main-menu-mobile-{{ section.id }}" id="MainMenuMobile-{{ section.id }}">
  <div class="main-menu-mobile__container">
    <div class="main-menu-mobile__list">
      {%- for block in section.blocks -%}
        <a
          href="{{ block.settings.link | default: '#' }}"
          class="main-menu-mobile__item"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.image != blank -%}
            <img
              src="{{ block.settings.image | img_url: '800x' }}"
              alt="{{ block.settings.image.alt | default: block.settings.text }}"
              class="main-menu-mobile__image"
              loading="lazy"
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
            >
          {%- else -%}
            <div class="main-menu-mobile__placeholder">
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
          {%- endif -%}

          <div class="main-menu-mobile__overlay">
            <p class="main-menu-mobile__text">{{ block.settings.text | escape }}</p>
            <span class="main-menu-mobile__icon">
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Main Menu Mobile",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "hide_on_desktop",
      "label": "Hide on Desktop",
      "default": true
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "banner",
      "name": "Banner",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Label",
          "default": "Ver colecciones"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Main Menu Mobile",
      "blocks": [
        {
          "type": "banner",
          "settings": {
            "text": "Ver colecciones"
          }
        },
        {
          "type": "banner",
          "settings": {
            "text": "Ver tal cosa"
          }
        },
        {
          "type": "banner",
          "settings": {
            "text": "Ver Tiendas"
          }
        }
      ]
    }
  ]
}
{% endschema %}
