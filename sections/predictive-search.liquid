{%- if predictive_search.performed -%}
  {%- assign predictive_count = predictive_search.resources.products.size -%}
  <div id="predictive-search-results" class="predictive-search-results">
    {%- if predictive_count > 0 -%}
      <div class="predictive-search-results__grid">
        {%- for product in predictive_search.resources.products -%}
          {%- liquid
            assign ps_badge_text = ''
            assign ps_badge_color = ''
            assign ps_badge_bg = ''
            if settings.show_collection_badge
              for col in product.collections
                if col.handle == settings.collection_badge_collection.handle
                  assign ps_badge_text = settings.collection_badge_text
                  assign ps_badge_color = settings.collection_badge_color
                  assign ps_badge_bg = settings.collection_badge_bg
                  break
                endif
              endfor
            endif
            if ps_badge_text == '' and settings.show_collection_badge_2
              for col in product.collections
                if col.handle == settings.collection_badge_collection_2.handle
                  assign ps_badge_text = settings.collection_badge_text_2
                  assign ps_badge_color = settings.collection_badge_color_2
                  assign ps_badge_bg = settings.collection_badge_bg_2
                  break
                endif
              endfor
            endif
            if ps_badge_text == '' and settings.show_collection_badge_3
              for col in product.collections
                if col.handle == settings.collection_badge_collection_3.handle
                  assign ps_badge_text = settings.collection_badge_text_3
                  assign ps_badge_color = settings.collection_badge_color_3
                  assign ps_badge_bg = settings.collection_badge_bg_3
                  break
                endif
              endfor
            endif
            if ps_badge_text == '' and settings.show_collection_badge_4
              for col in product.collections
                if col.handle == settings.collection_badge_collection_4.handle
                  assign ps_badge_text = settings.collection_badge_text_4
                  assign ps_badge_color = settings.collection_badge_color_4
                  assign ps_badge_bg = settings.collection_badge_bg_4
                  break
                endif
              endfor
            endif
          -%}
          <a href="{{ product.url }}" class="predictive-search-results__card" tabindex="-1">
            <div class="predictive-search-results__card-image">
              {%- if ps_badge_text != '' -%}
                <span class="predictive-search-badge" style="color:{{ ps_badge_color }};background:{{ ps_badge_bg }}">{{ ps_badge_text }}</span>
              {%- endif -%}
              {%- if product.featured_image -%}
                {{ product.featured_image | image_url: width: 400 | image_tag: loading: 'lazy', alt: product.title, width: 400, height: 400 }}
              {%- else -%}
                <div class="predictive-search-results__no-image">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="32" height="32"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
                </div>
              {%- endif -%}
            </div>
            <div class="predictive-search-results__card-info">
              <span class="predictive-search-results__card-title">{{ product.title }}</span>
              <span class="predictive-search-results__card-price">
                {%- if product.compare_at_price > product.price -%}
                  <s class="predictive-search-results__card-price--compare">{{ product.compare_at_price | money }}</s>
                {%- endif -%}
                {{ product.price | money }}
              </span>
            </div>
          </a>
        {%- endfor -%}
      </div>

      <div class="predictive-search-results__view-all">
        <a href="{{ routes.search_url }}?q={{ predictive_search.terms | url_encode }}&type=product" data-predictive-search-view-all>
          {{ 'general.search.view_all' | t: count: predictive_count }}
        </a>
      </div>
    {%- else -%}
      <div class="predictive-search-results__empty">
        <span>{{ 'general.search.search_no_result' | t }} "<strong>{{ predictive_search.terms }}</strong>"</span>
        <a href="{{ routes.search_url }}?q={{ predictive_search.terms | url_encode }}&type=product">
          {{ 'general.search.search' | t }}
        </a>
      </div>
    {%- endif -%}

    <span class="visually-hidden" data-predictive-search-live-region-count-value>
      {%- if predictive_count == 0 -%}
        {{ 'templates.search.no_results' | t: terms: predictive_search.terms }}
      {%- else -%}
        {{ 'general.search.view_all' | t: count: predictive_count }}
      {%- endif -%}
    </span>
  </div>
{%- endif -%}
