{{ 'component-header-single-line.css' | asset_url | stylesheet_tag }}
{%- if settings.enable_layout_rtl -%}
  {% style %}
    @media (min-width: 1025px) {
      .layout_rtl .header-top--wrapper .customer-service-text {
        margin-left: 25px;
        margin-right: 0;
        text-align: right;
      }
      .layout_rtl .header-top--wrapper .header-top--right .header__icon + .header__icon {
        margin-left: 0;
        margin-right: 35px;
      }
      .layout_rtl .header-bottom--wrapper .header-bottom-right .help-item {
        margin-right: 0;
        padding-right: 0;
        margin-left: 14px;
        padding-left: 20px;
      }
      .layout_rtl .header-bottom--wrapper .header-bottom-right .help-item:before {
        right: auto;
        left: 0;
      }
      .layout_rtl .top-language-currency.enable-currency .halo-top-language .disclosure__button .text {
        margin-right: 10px;
        margin-left: 0;
      }
      .layout_rtl .top-language-currency .halo-top-language + .halo-top-currency:before {
        left: auto;
        right: 0;
      }
      .layout_rtl .top-language-currency .halo-top-language .disclosure__button {
        padding-left: 0;
      }
      .layout_rtl .top-language-currency .halo-top-language + .halo-top-currency {
        margin-left: 0;
        margin-right: 2px;
        padding-left: 0;
        padding-right: 8px;
      }
      .layout_rtl .header__group .header__icon--cart svg {
        margin-left: 0;
      }
      .layout_rtl .header-top--wrapper .quickSearchResultsWrap {
        left: auto;
        right: 0;
      }
      .layout_rtl .header-language_currency .top-language-currency.enable-currency .dropdown-language {
        left: 42px;
        right: auto;
      }
      .layout_rtl .header-language_currency .top-language-currency .dropdown-currency,
      .layout_rtl .header-language_currency .top-language-currency.show .dropdown-currency {
        right: auto;
        left: 0;
      }
    }

    @media (min-width: 1441px) {
      .layout_rtl .header-top--wrapper .customer-service-text {
        margin-left: 50px;
      }
    }
  {% endstyle %}
{%- endif -%}

{% style %}
  /* Hide desktop header on mobile */
  @media screen and (max-width: 989px) {
    .header-single-line,
    .section-header-single-line {
      display: none !important;
    }
  }
{% endstyle %}

<header
  class="header header-single-line"
  style="--spacing-l-r: {{ section.settings.padding_full_width }}px; --padding-top: {{ section.settings.padding_top }}px; --padding-bottom: {{ section.settings.padding_bottom }}px; --bg-color: {% if section.settings.header_bg_gradient != blank %}{{ section.settings.header_bg_gradient }}{% else %}{{ section.settings.header_bg }}{% endif %}; --header-text-transform: {{ section.settings.header_text_transform }}"
>
  <div class="container container-{{ section.settings.container }}">
    <div class="header-single-line__content size--{{ section.blocks.size }}">
      {%- for block in section.blocks -%}
        <div
          class="header-single-line__item header-single-line__item--{{ block.type }}"
          {% if block.type == 'logo' %}
            style="--logo-width: {{ block.settings.logo_width }}px; --logo-font-size: {{ block.settings.logo_font_size }}px; --logo-font-weight: {{ block.settings.logo_font_weight }}; --logo-color: {{ block.settings.logo_color }}"
          {% endif %}
        >
          {%- case block.type -%}
            {%- when 'logo' -%}
              <div class="header__logo text-left clearfix">
                <div class="header__heading">
                  <a href="{{ routes.root_url }}" class="header__heading-link focus-inset">
                    {%- if block.settings.lottie_json_url != blank -%}
                      <div
                        id="lottie-logo-{{ section.id }}-{{ forloop.index }}"
                        class="lottie-logo"
                        aria-label="{{ shop.name }}"
                        role="img"
                      ></div>
                      <script>
                        document.addEventListener('DOMContentLoaded', function() {
                            try {
                                if (window.lottie) {
                                    window.lottie.loadAnimation({
                                        container: document.getElementById('lottie-logo-{{ section.id }}-{{ forloop.index }}'),
                                        renderer: 'svg',
                                        loop: {{ block.settings.lottie_loop | default: true }},
                                        autoplay: {{ block.settings.lottie_autoplay | default: true }},
                                        path: '{{ block.settings.lottie_json_url | escape }}'
                                    });
                                }
                            } catch(e) { /* no-op */ }
                        });
                      </script>
                    {%- elsif block.settings.logo != blank -%}
                      {%- liquid
                        assign logo = block.settings.logo
                        assign logo_width = block.settings.logo_width
                        assign logo_height = logo_width | divided_by: logo.aspect_ratio | round
                        assign logo_alt = logo.alt | default: shop.name | escape
                      -%}

                      {{
                        logo
                        | image_url: width: 300
                        | image_tag:
                          class: 'header__heading-logo motion-reduce',
                          widths: '50, 100, 150, 200, 250, 300, 400, 500',
                          height: logo_height,
                          width: logo_width,
                          alt: logo_alt
                      }}
                    {%- else -%}
                      <span class="h2 {{ block.settings.logo_text_transform }}">
                        {%- if block.settings.logo_text != blank -%}
                          {{- block.settings.logo_text -}}
                        {%- else -%}
                          {{- shop.name -}}
                        {%- endif -%}
                      </span>
                    {%- endif -%}
                  </a>
                </div>
              </div>
            {%- when 'benefits' -%}
              <div 
                class="header-benefits-slider" 
                id="HeaderBenefits-{{ section.id }}"
                style="box-shadow: 0 0 0 2px {% if block.settings.border_color != blank and block.settings.border_color != 'rgba(0,0,0,0)' %}{{ block.settings.border_color }}{% else %}{{ block.settings.color | default: '#000000' }}{% endif %} !important; border-radius: {{ block.settings.border_radius | default: 6 }}px !important; background: rgba(0,0,0,0.03) !important;"
              >
                <div
                  class="benefits-wrapper"
                  style="--benefit-color: {{ block.settings.color | default: '#000000' }}; --benefit-size: {{ block.settings.text_size | default: 15 }}px; border: 0 !important;"
                >
                  <div class="benefits-inner" id="BenefitsInner-{{ section.id }}">
                    {% if block.settings.text_1 != blank %}
                      <div class="benefit-item">
                        {% if block.settings.icon_1 == 'shipping' -%}
                          {%- render 'icon-shipping-truck' -%}
                        {%- else -%}
                          {%- render 'icon-checkmark' -%}
                        {%- endif %}
                        <span>{{ block.settings.text_1 }}</span>
                      </div>
                    {% endif %}
                    {% if block.settings.text_2 != blank %}
                      <div class="benefit-item">
                        {% if block.settings.icon_2 == 'shipping' -%}
                          {%- render 'icon-shipping-truck' -%}
                        {%- else -%}
                          {%- render 'icon-checkmark' -%}
                        {%- endif %}
                        <span>{{ block.settings.text_2 }}</span>
                      </div>
                    {% endif %}
                    {% if block.settings.text_3 != blank %}
                      <div class="benefit-item">
                        {% if block.settings.icon_3 == 'shipping' -%}
                          {%- render 'icon-shipping-truck' -%}
                        {%- else -%}
                          {%- render 'icon-checkmark' -%}
                        {%- endif %}
                        <span>{{ block.settings.text_3 }}</span>
                      </div>
                    {% endif %}
                    {% if block.settings.show_bcv %}
                      <div class="benefit-item">
                        {% render 'icon-heart' %}
                        <span>
                          {{ block.settings.bcv_text -}}
                          : <span id="bcv-rate-{{ section.id }}">{{ block.settings.bcv_rate }}</span>
                        </span>
                      </div>
                    {% endif %}
                  </div>
                </div>
              </div>
              <style>
                .header-single-line__item--logo {
                  flex: 0 0 auto !important;
                  max-width: 130px !important;
                  min-width: 0 !important;
                  width: auto !important;
                  margin: 0 !important;
                  padding-right: 15px !important;
                }
                .header-single-line .header__heading-link {
                  display: block;
                  max-width: 100%;
                }
                .header-single-line .header__heading-logo {
                  max-width: 100%;
                  height: auto !important;
                  object-fit: contain;
                }
                .header-single-line__item--benefits {
                  flex: 1 1 auto !important;
                  display: flex;
                  align-items: center;
                  min-width: 0;
                  justify-content: center;
                }
                .header-benefits-slider {
                  height: 42px; 
                  overflow: hidden;
                  position: relative;
                  width: fit-content;
                  min-width: 280px;
                  max-width: 100%;
                  padding: 0 15px;
                  box-sizing: border-box !important;
                  background: transparent !important;
                  margin: 0 auto;
                  z-index: 100; /* Maximum visibility */
                  display: flex;
                  align-items: center;
                }
                .benefits-wrapper {
                  height: 38px; /* 42 - 4 for borders */
                  width: 100%;
                  display: flex;
                  align-items: flex-start;
                  overflow: hidden;
                }
                .benefits-inner {
                  width: 100%;
                  display: flex;
                  flex-direction: column;
                  transition: transform 0.6s cubic-bezier(0.65, 0, 0.35, 1);
                }
                .benefit-item {
                  height: 38px;
                  min-height: 38px;
                  display: flex;
                  align-items: center;
                  gap: 10px;
                  color: var(--benefit-color);
                  font-size: var(--benefit-size);
                  font-weight: 700;
                  white-space: nowrap;
                  justify-content: center;
                  width: 100%;
                  box-sizing: border-box;
                }
                .benefit-item svg {
                  width: 18px;
                  height: 18px;
                  flex-shrink: 0;
                }
                @media (max-width: 768px) {
                  .header-benefits-slider {
                    display: none !important;
                  }
                }
              </style>
              <script>
                (function() {
                  {% if block.settings.show_bcv and block.settings.auto_update_bcv %}
                  const updateBCV = (id) => {
                    const el = document.getElementById(id);
                    if (el) {
                      fetch('https://ve.dolarapi.com/v1/dolares/oficial')
                        .then(r => r.json())
                        .then(d => { if (d && d.promedio) el.textContent = parseFloat(d.promedio).toLocaleString('es-VE', { minimumFractionDigits: 2 }); });
                    }
                  };
                  updateBCV('bcv-rate-{{ section.id }}');
                  {% endif %}

                  const inner = document.getElementById('BenefitsInner-{{ section.id }}');
                  if (!inner) return;
                  const items = inner.querySelectorAll('.benefit-item');
                  if (items.length < 2) return;
                  let index = 0;
                  setInterval(() => {
                    index = (index + 1) % items.length;
                    inner.style.transform = `translateY(-${index * items[0].offsetHeight}px)`;
                  }, 4000);
                })();
              </script>
            {%- when 'search' -%}
              <div
                class="header__search clearfix{% if block.settings.show_box_shadow %} show-box-shadow{% endif %}"
                style="--bg-search-color: {{ block.settings.bg_search_color }}; --search-color: {{ block.settings.search_color }}; --search-icon-color: {{ block.settings.search_icon_color }}; --search-border-radius: {{ block.settings.search_border_radius }}px"
              >
                {% render 'predictive-search-form' %}
              </div>
            {%- when 'text' -%}
              {% if block.settings.customer_service_text != blank %}
                <div class="header__iconItem header__group text-right">
                  <div
                    class="customer-service-text"
                    style="--text-size: {{ block.settings.text_size }}px; --text-color: {{ block.settings.color }}"
                  >
                    {{ block.settings.customer_service_text }}
                  </div>
                </div>
              {% endif %}
            {%- when 'wishlist' -%}
              {%- if settings.show_wishlist -%}
                <div class="header__iconItem header__group" style="--color: {{ block.settings.color }}">
                  <a
                    href="{{ pages['wish-list'].url }}"
                    class="header__icon header__icon--wishlist link link--text focus-inset"
                  >
                    {% render 'icon-heart-2' %}
                    <span class="wishlist-text">
                      {{ 'wishlist.general.wishlist' | t }}
                    </span>
                    <div class="wishlist-count-bubble"><span class="text" aria-hidden="true" data-wishlist-count></span></div>
                  </a>
                </div>
              {%- endif -%}
            {%- when 'gift_cards' -%}
              <div class="header__iconItem header__group" style="--color: {{ block.settings.color }}">
                <a
                  {% if block.settings.link_giftcards == blank %}
                    role="link" aria-disabled="true"
                  {% else %}
                    href="{{ block.settings.link_giftcards }}"
                  {% endif %}
                  class="header__icon header__icon--giftcards link link--text focus-inset"
                >
                  {% render 'icon-giftcards' %}
                  <span class="giftcards-text">
                    {{ block.settings.text_giftcards }}
                  </span>
                </a>
              </div>
            {%- when 'customer' -%}
              <div class="header__iconItem header__group" style="--color: {{ block.settings.color }}">
                {%- if shop.customer_accounts_enabled -%}
                  {% if routes.account_login_url contains '/account/login' %}
                    {% assign is_contained = true %}
                  {% else %}
                    {% assign is_contained = false %}
                  {% endif %}
                  <a
                    href="{{ routes.account_login_url }}"
                    class="header__icon header__icon--account link link--text"
                    {% if is_contained %}
                      data-open-auth-sidebar
                    {% endif %}
                  >
                    {% render 'icon-account-2' %}
                    <span class="customer-links">
                      {%- liquid
                        if customer
                          echo 'customer.account_fallback' | t
                        else
                          echo 'customer.sign_in' | t
                        endif
                      -%}
                    </span>
                  </a>
                {%- endif -%}
              </div>
            {%- when 'cart' -%}
              <div
                class="header__iconItem header__group"
                style="--color: {{ block.settings.color }}; --cart-bg-item: {{ block.settings.cart_bg_item }}; --cart-color-item: {{ block.settings.cart_color_item }}; --cart-item-font-size: {{ block.settings.cart_item_font_size }}px"
              >
                <a
                  href="{{ routes.cart_url }}"
                  class="header__icon header__icon--cart link link--text focus-inset cart-icon-bubble"
                  {% if settings.show_quick_cart %}
                    data-cart-sidebar
                  {% endif %}
                >
                  {% render 'icon-cart-03' %}
                  <span class="cart-text">{{ 'general.cart.cart' | t }}</span>
                  <div class="cart-count-bubble">
                    {%- if cart.item_count < 100 -%}
                      <span class="text" aria-hidden="true" data-cart-count>{{ cart.item_count }}</span>
                    {%- endif -%}
                    <span class="visually-hidden">{{ 'sections.header.cart_count' | t: count: cart.item_count }}</span>
                  </div>
                </a>
              </div>
          {%- endcase -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header - Single-Line",
  "limit": 1,
  "class": "section-header-single-line",
  "settings": [
    {
      "type": "paragraph",
      "content": "*You should only activate \/ use \"Header\" you want, don't use the redundant headers which may not optimize for performance."
    },
    {
      "type": "select",
      "id": "container",
      "label": "t:sections.layout.container.option",
      "default": "1370",
      "options": [
        {
          "value": "1170",
          "label": "t:sections.layout.container.option4"
        },
        {
          "value": "1370",
          "label": "t:sections.layout.container.option8"
        },
        {
          "value": "1470",
          "label": "t:sections.layout.container.option5"
        },
        {
          "value": "1570",
          "label": "t:sections.layout.container.option6"
        },
        {
          "value": "1770",
          "label": "t:sections.layout.container.option3"
        },
        {
          "value": "full",
          "label": "t:sections.layout.container.option2"
        }
      ]
    },
    {
      "type": "range",
      "id": "padding_full_width",
      "label": "t:sections.layout.container.padding_full_width",
      "min": 0,
      "max": 75,
      "step": 5,
      "unit": "t:sections.layout.fontsize.fontsize_title.unit",
      "default": 0,
      "info": "t:sections.layout.container.info_full_width"
    },
    {
      "type": "color",
      "id": "header_bg",
      "label": "t:settings_schema.colors.settings.colors_name.background_color",
      "default": "#234bbb"
    },
    {
      "type": "color_background",
      "id": "header_bg_gradient",
      "label": "t:settings_schema.colors.settings.colors_name.background_color_gradient"
    },
    {
      "type": "select",
      "id": "header_text_transform",
      "label": "t:settings_schema.typography.settings.text_transform.label",
      "default": "capitalize",
      "options": [
        {
          "value": "none",
          "label": "t:settings_schema.typography.settings.text_transform.options__1"
        },
        {
          "value": "capitalize",
          "label": "t:settings_schema.typography.settings.text_transform.options__2"
        },
        {
          "value": "uppercase",
          "label": "t:settings_schema.typography.settings.text_transform.options__3"
        },
        {
          "value": "lowercase",
          "label": "t:settings_schema.typography.settings.text_transform.options__4"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.main-product.settings.general.spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:sections.main-list-collections.settings.spacing.mg_top",
      "default": 18
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:sections.main-list-collections.settings.spacing.mg_bottom",
      "default": 18
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "t:sections.header.blocks.header__2.content",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "t:sections.header.settings.logo.label__1"
        },
        {
          "type": "url",
          "id": "lottie_json_url",
          "label": "Logo animado (Lottie .json)",
          "info": "Sube el .json en Archivos y pega su URL"
        },
        {
          "type": "checkbox",
          "id": "lottie_autoplay",
          "label": "Autoplay",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "lottie_loop",
          "label": "Loop",
          "default": true
        },
        {
          "type": "range",
          "id": "logo_width",
          "min": 50,
