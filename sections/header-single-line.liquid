        }
      ]
    },
    {
      "type": "search",
      "name": "Search",
      "limit": 1,
      "settings": [
        {
          "type": "header",
          "content": "t:sections.header.settings.header_top.search"
        },
        {
          "type": "checkbox",
          "id": "show_box_shadow",
          "label": "t:settings_schema.typography.settings.type_button_font.show_box_shadow"
        },
        {
          "type": "color",
          "id": "search_color",
          "label": "t:sections.header.settings.header_top.search_color_text",
          "default": "#323232"
        },
        {
          "type": "color",
          "id": "search_icon_color",
          "label": "t:sections.header.settings.header_top.search_color_icon",
          "default": "#323232"
        },
        {
          "type": "color",
          "id": "bg_search_color",
          "label": "t:settings_schema.colors.settings.colors_name.background_color",
          "default": "#fafafa"
        },
        {
          "type": "range",
          "id": "search_border_radius",
          "min": 0,
          "max": 50,
          "step": 1,
          "unit": "t:sections.header.settings.logo_width.unit",
          "label": "t:sections.header.settings.header_top.search_border_radius",
          "default": 5
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "limit": 1,
      "settings": [
        {
          "type": "richtext",
          "id": "customer_service_text",
          "label": "t:sections.header.settings.header_top.customer_service_text",
          "default": "<p>Need Help?</p><p><strong>(012) 345-6789</strong></p>"
        },
        {
          "type": "range",
          "id": "text_size",
          "label": "t:settings_schema.typography.settings.font_size.label",
          "min": 12,
          "max": 30,
          "step": 1,
          "unit": "t:sections.header.settings.logo.unit",
          "default": 16
        },
        {
          "type": "color",
          "id": "color",
          "label": "t:sections.header.settings.header_top.label__4",
          "default": "#ffffff"
        }
      ]
    },
    {
      "type": "wishlist",
      "name": "Wish List",
      "limit": 1,
      "settings": [
        {
          "type": "color",
          "id": "color",
          "label": "t:sections.header.settings.header_top.label__4",
          "default": "#ffffff"
        }
      ]
    },
    {
      "type": "gift_cards",
      "name": "Gift Cards",
      "limit": 1,
