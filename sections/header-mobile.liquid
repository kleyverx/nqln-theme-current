<link rel="stylesheet" href="{{ 'component-menu-mobile.css' | asset_url }}" media="all" onload="this.media='all'">
<noscript>{{ 'component-menu-mobile.css' | asset_url | stylesheet_tag }}</noscript>

<style>
  .header-mobile--wrapper {
    display: flex !important;
    align-items: center !important;
    justify-content: space-between !important;
    width: 100% !important;
  }
  .header-mobile__left,
  .header-mobile__right {
    display: flex !important;
    align-items: center !important;
    flex: 1 !important;
    gap: 12px; /* Reducido un poco para dar espacio a la barra */
  }
  .header-mobile__right {
    justify-content: flex-end !important;
  }
  .header-mobile__center {
    flex: none !important;
    display: flex !important;
    justify-content: center !important;
    margin: 0 10px;
  }
  .header-mobile__item {
    flex: none !important;
  }
  .header-mobile > .container {
    padding: 0 20px !important;
  }

  /* Estilo de la Barra de Búsqueda (Elegant Pill) */
  .header__search-pill {
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    background: #ffffff !important;
    border: 1px solid #eeeeee !important;
    border-radius: 100px !important; /* Totalmente redondeado para suavidad */
    padding: 0 15px !important;
    gap: 8px !important;
    height: 36px !important;
    min-width: 95px !important;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
    box-shadow: 0 3px 6px rgba(0, 0, 0, 0.03); /* Sombra muy suave */
  }
  .header__search-pill:active {
    background: #f8f8f8 !important;
    transform: scale(0.96);
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.02);
  }
  .header__search-placeholder {
    font-size: 13px !important;
    color: #1a1a1a !important;
    font-weight: 500 !important;
    letter-spacing: 0.2px !important;
  }
  .header__search-pill .icon-search {
    width: 15px !important;
    height: 15px !important;
    color: #333 !important;
    stroke-width: 2.5 !important;
  }

  /* Ajustes para el modal de búsqueda */
  .header__icon--search svg {
    width: 22px;
    height: 22px;
  }
  .modal__toggle-open.icon-search {
    width: 24px;
    height: 24px;
    stroke-width: 2.2;
  }

  /* Absolute removal of any borders, shadows, or lines from the mobile header */
  .section-header-mobile,
  .header-mobile,
  .sticky-header-mobile-wrapper,
  sticky-header-mobile,
  [id*='header-mobile'] {
    border: 0 !important;
    border-bottom: 0 !important;
    box-shadow: none !important;
    outline: none !important;
    background-image: none !important;
  }

  /* Remove any decoration from pseudo-elements (some themes use ::after for lines) */
  .header-mobile::after,
  .header-mobile::before,
  sticky-header-mobile::after,
  sticky-header-mobile::before {
    display: none !important;
    content: none !important;
  }

  .header-mobile {
    background-color: var(--bg-color) !important;
    padding-top: env(safe-area-inset-top, 0px);
    position: relative;
    z-index: 10;
    overflow: visible;
  }
  .header-mobile__item--wishlist .header__icon--wishlist {
    position: relative;
  }
  .header-mobile__item--wishlist .icon-wishlist {
    width: 22px;
    height: 22px;
    fill: #000000;
    stroke: none;
  }
  .header-mobile__item--wishlist .wishlist-count-bubble {
    position: absolute;
    top: -4px;
    right: -6px;
    width: 18px;
    height: 18px;
    min-width: 18px;
    min-height: 18px;
    border-radius: 50%;
    background: #20b19e;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    line-height: 18px;
    text-align: center;
  }
  .header-mobile__item--wishlist .wishlist-count-bubble .text {
    font-size: 10px;
    font-weight: 700;
    color: #fff;
    line-height: 1;
    display: block;
    text-align: center;
  }
  #page-loading-bar {
    overflow: hidden;
  }

  /* Category bar */
  .header-category-bar {
    background: var(--bg-color, #fff);
    position: relative;
    border-top: 1px solid #f2f2f2;
  }
  .header-category-bar::after {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 60px;
    height: 100%;
    background: linear-gradient(to right, transparent, var(--bg-color, #fff));
    pointer-events: none;
    z-index: 2;
  }
  .header-category-list {
    display: flex;
    list-style: none;
    padding: 0 70px 0 20px;
    margin: 0;
    gap: 20px;
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    align-items: center;
    height: 46px;
    scroll-snap-type: x mandatory;
  }
  .header-category-list::-webkit-scrollbar {
    display: none;
  }
  .header-category-list li {
    flex-shrink: 0;
    scroll-snap-align: start;
  }
  .header-category-list li:first-child {
    padding-left: 8px;
  }
  .header-category-list a {
    text-decoration: none;
    color: #888;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 8px;
    white-space: nowrap;
    position: relative;
    padding: 10px 0;
  }
  .header-category-list img {
    width: 18px;
    height: 18px;
    border-radius: 4px;
    object-fit: contain;
  }
  .header-category-list li.active a {
    color: #20b19e;
    font-weight: 800;
  }
  .header-category-list li.active a::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background: #20b19e;
    border-radius: 1px;
  }

  /* Hide mobile header on desktop */
  @media screen and (min-width: 990px) {
    .section-header-mobile,
    [id*='header-mobile'] {
      display: none !important;
    }
  }
</style>

{%- liquid
  assign left_content = ''
  assign center_content = ''
  assign right_content = ''
  assign found_logo = false
-%}

{%- for block in section.blocks -%}
  {%- capture content -%}
    {%- case block.type -%}
      {%- when 'menu' -%}
        <div class="header-mobile__item header-mobile__item--menu">
          <div class="header-mobile--icon item__mobile--hamburger" style="--i-color: {{ block.settings.color }}">
            <button type="button" class="mobileMenu-toggle" data-mobile-menu aria-label="menu"><span class="mobileMenu-toggle__Icon"></span></button>
          </div>
        </div>
      {%- when 'search' -%}
        <div class="header-mobile__item header-mobile__item--search">
          <details-modal class="header__iconItem header__search--pill" style="--i-color: {{ block.settings.color }}">
            <details><summary class="header__search-pill-wrapper link link--text focus-inset modal__toggle" aria-haspopup="dialog" aria-label="search" data-search-mobile>
              <div class="header__search-pill">
                {% render 'icon-search', class: 'icon icon-search' %}
                <span class="header__search-placeholder">{{ 'Buscar' }}</span>
              </div>
            </summary></details>
          </details-modal>
        </div>
      {%- when 'logo' -%}
        <div class="header-mobile__item header-mobile__item--logo">
          <div class="header-mobile--icon" style="--logo-font-size: {{ block.settings.logo_font_size }}px; --logo-font-weight: {{ block.settings.logo_font_weight }}; --logo-color: {{ block.settings.logo_color }}">
            {%- assign logo = block.settings.logo_mobile | default: block.settings.logo -%}
            {%- assign logo_width = block.settings.logo_width_mobile | default: 65 -%}
            {%- if logo != blank -%}
              {%- assign logo_height = logo_width | divided_by: logo.aspect_ratio | round -%}
              <a href="{{ routes.root_url }}" class="header__heading-link">
                {{ logo | image_url: width: 300 | image_tag:
                  class: 'header__heading-logo',
                  widths: '50, 100, 150, 200, 250, 300',
                  width: logo_width,
                  height: logo_height,
                  loading: 'lazy',
                  alt: logo.alt | default: shop.name
                }}
              </a>
            {%- else -%}
              <a href="{{ routes.root_url }}" class="header__heading-link">
                <span class="h2 {{ block.settings.logo_text_transform }}">{{ block.settings.logo_text | default: shop.name }}</span>
              </a>
            {%- endif -%}
          </div>
        </div>
      {%- when 'customer' -%}
        {%- if shop.customer_accounts_enabled -%}
          {%- if settings.show_wishlist -%}
            <div class="header-mobile__item header-mobile__item--wishlist">
              <div class="header-mobile--icon" style="--i-color: #000000">
                <a href="{{ pages['wish-list'].url | default: '/pages/wish-list' }}" class="header__icon header__icon--wishlist link link--text focus-inset">
                  {% render 'icon-heart-2' %}
                  <div class="wishlist-count-bubble"><span class="text" aria-hidden="true" data-wishlist-count></span></div>
                </a>
              </div>
            </div>
          {%- endif -%}
          <div class="header-mobile__item header-mobile__item--customer">
            <div class="header-mobile--icon" style="--i-color: {{ block.settings.color }}">
              <a href="{{ routes.account_login_url }}" class="header__icon header__icon--account link link--text focus-inset"{% if routes.account_login_url contains '/account/login' %} data-open-auth-sidebar{% endif %}>
                {%- case block.settings.icon -%}
                  {%- when '1' -%}{% render 'icon-account' %}
                  {%- when '2' -%}{% render 'icon-account-2' %}
                {%- endcase -%}
              </a>
            </div>
          </div>
          <div class="header-mobile__item header-mobile__item--BON-hyperlink">
            {% render 'nqln-scan-widget' %}
          </div>
        {%- endif -%}
      {%- when 'cart' -%}
        <div class="header-mobile__item header-mobile__item--cart">
          <div class="header-mobile--icon" style="--i-color: {{ block.settings.color }}; --color-bubble: {{ block.settings.color_bubble }}; --bg-bubble: {{ block.settings.bg_bubble }}">
            <a href="{{ routes.cart_url }}" class="header__icon header__icon--cart link link--text focus-inset" id="cart-icon-bubble"{% if settings.show_quick_cart %} data-cart-sidebar{% endif %}>
              {%- case block.settings.icon -%}
                {%- when '1' -%}{% render 'icon-cart' %}
                {%- when '2' -%}{% render 'icon-cart-02' %}
                {%- when '3' -%}{% render 'icon-cart-03' %}
                {%- when '4' -%}{% render 'icon-cart-04' %}
              {%- endcase -%}
              <div class="cart-count-bubble">
                {%- if cart.item_count < 100 -%}
                  <span class="text" aria-hidden="true" data-cart-count>{{ cart.item_count }}</span>
                {%- endif -%}
              </div>
            </a>
          </div>
        </div>
    {%- endcase -%}
  {%- endcapture -%}

  {%- liquid
    if block.type == 'logo'
      assign found_logo = true
      assign center_content = content
    elsif found_logo == false
      assign left_content = left_content | append: content
    else
      assign right_content = right_content | append: content
    endif
  -%}
{%- endfor -%}

{%- if section.settings.sticky_header_type != 'none' -%}
  <sticky-header-mobile class="sticky-header-mobile-wrapper">
{%- endif -%}
<div
  class="header-mobile"
  style="--bg-color: {{ section.settings.background }}; --p-top: {{ section.settings.padding_top }}px; --p-bottom: {{ section.settings.padding_bottom }}px"
>
  <div class="container">
    <div class="header-mobile__wrapper header-mobile--wrapper">
      <div class="header-mobile__left">
        {{ left_content }}
      </div>
      <div class="header-mobile__center">
        {{ center_content }}
      </div>
      <div class="header-mobile__right">
        {{ right_content }}
      </div>
    </div>
  </div>
  <div id="page-loading-bar"></div>
  {%- if section.settings.category_menu != blank -%}
    <nav class="header-category-bar" id="headerCategoryBar">
      <ul class="header-category-list">
        {%- for link in linklists[section.settings.category_menu].links -%}
          {%- assign collection_img = blank -%}
          {%- if link.type == 'collection_link' -%}
            {%- assign collection_img = link.object.featured_image | default: link.object.image -%}
          {%- endif -%}
          <li class="{% if link.active %}active{% endif %}">
            <a href="{{ link.url }}">
              {%- if collection_img != blank -%}
                <img
                  src="{{ collection_img | image_url: width: 60 }}"
                  alt="{{ link.title }}"
                  loading="lazy"
                  width="18"
                  height="18"
                >
              {%- endif -%}
              <span>{{ link.title }}</span>
            </a>
          </li>
        {%- endfor -%}
      </ul>
    </nav>
  {%- endif -%}
</div>
{%- if section.settings.sticky_header_type != 'none' -%}
  </sticky-header-mobile>
{%- endif -%}

<script>
  // Register custom element (required for <sticky-header-mobile> tag)
  if (!customElements.get('sticky-header-mobile')) {
    customElements.define('sticky-header-mobile', class extends HTMLElement {});
  }

  (function () {
    // Make header sticky
    var header = document.querySelector('.section-header-mobile');
    if (header) header.classList.add('shopify-section-header-sticky');

    // Category bar scroll hide/show
    var catBar = document.getElementById('headerCategoryBar');
    if (!catBar) return;

    var anchorY = 0;
    var peakY = 0;
    var hidden = false;

    window.addEventListener(
      'scroll',
      function () {
        var y = window.pageYOffset || 0;
        if (y <= 50) {
          if (hidden) {
            hidden = false;
            catBar.style.display = '';
          }
          anchorY = y;
          peakY = y;
        } else if (!hidden) {
          if (y > anchorY + 80) {
            hidden = true;
            catBar.style.display = 'none';
            peakY = y;
          }
        } else {
          if (y > peakY) peakY = y;
          if (y < peakY - 40) {
            hidden = false;
            catBar.style.display = '';
            anchorY = y;
            peakY = y;
          }
        }
      },
      { passive: true }
    );

    // Active link
    function updateActive() {
      var p = window.location.pathname;
      catBar.querySelectorAll('li').forEach(function (li) {
        var a = li.querySelector('a');
        if (!a) return;
        var lp = new URL(a.href, location.origin).pathname;
        var active = (lp === '/' && p === '/') || (lp !== '/' && p.indexOf(lp) === 0);
        if (active) {
          li.classList.add('active');
        } else {
          li.classList.remove('active');
        }
        if (active)
          setTimeout(function () {
            li.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
          }, 50);
      });
    }
    updateActive();
    document.addEventListener('page:transition', updateActive);
    window.addEventListener('popstate', updateActive);
  })();
</script>

