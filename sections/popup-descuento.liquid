{% schema %}
{
  "name": "t:sections.popup-descuento.name",
  "settings": [
    {
      "type": "image_picker",
      "id": "popup_image",
      "label": "Imagen del Popup"
    },
    {
      "type": "text",
      "id": "popup_title",
      "label": "Título del Popup",
      "default": "¡Oferta Especial!"
    },
    {
      "type": "textarea",
      "id": "popup_subtitle",
      "label": "Subtítulo del Popup",
      "default": "Descubre nuestra colección con descuentos exclusivos."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Texto del Botón",
      "default": "Ver la colección"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Enlace del Botón"
    },
    {
      "type": "color",
      "id": "button_background_color",
      "label": "Color de Fondo del Botón",
      "default": "#20b19e"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Color del Texto del Botón",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_background_color",
      "label": "Color de Fondo del Botón (Hover)",
      "default": "#1a927b"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Color del Texto del Botón (Hover)",
      "default": "#ffffff"
    }
  ]
}
{% endschema %}

