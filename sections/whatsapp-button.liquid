<style>
  /* ============================================
     WHATSAPP FLOAT — NQLN PREMIUM STYLE
     ============================================ */

  .whatsapp-float-container {
    position: fixed;
    bottom: 28px;
    right: 24px;
    z-index: 999;
    font-family: var(--font-family-1, 'Century Gothic', sans-serif);
  }

  .whatsapp-float {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 14px;
  }

  /* ---- BOTÓN PRINCIPAL ---- */
  .whatsapp-float__btn {
    position: relative;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.15);
    cursor: pointer;
    background: linear-gradient(135deg, var(--wa-accent, #25d366), #128c7e);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 6px 24px rgba(37, 211, 102, 0.4), 0 2px 8px rgba(0, 0, 0, 0.15),
      inset 0 1px 0 rgba(255, 255, 255, 0.2);
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.35s ease;
    outline: none;
    -webkit-tap-highlight-color: transparent;
    z-index: 2;
  }

  .whatsapp-float__btn:hover {
    transform: scale(1.12) rotate(-8deg);
    background: linear-gradient(135deg, var(--wa-accent-hover, #1ebe57), #0e7a6e);
    box-shadow: 0 10px 32px rgba(37, 211, 102, 0.5), 0 4px 14px rgba(0, 0, 0, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.25);
  }

  .whatsapp-float__btn:active {
    transform: scale(0.94);
    transition-duration: 0.1s;
  }

  .whatsapp-float__btn-icon {
    width: 32px;
    height: 32px;
    position: relative;
    z-index: 1;
    filter: drop-shadow(0 1px 2px rgba(0, 0, 0, 0.2));
  }

  /* Pulse animation */
  .whatsapp-float__btn-pulse {
    position: absolute;
    inset: -6px;
    border-radius: 50%;
    background: var(--wa-accent, #25d366);
    opacity: 0;
    animation: waPulse 2.8s cubic-bezier(0.4, 0, 0.2, 1) infinite;
    z-index: 0;
  }

  /* Ring animation */
  .whatsapp-float__btn-ring {
    position: absolute;
    inset: -3px;
    border-radius: 50%;
    border: 2px solid var(--wa-accent, #25d366);
    opacity: 0;
    animation: waRing 2.8s cubic-bezier(0.4, 0, 0.2, 1) infinite 0.4s;
    z-index: 0;
  }

  @keyframes waPulse {
    0% {
      transform: scale(1);
      opacity: 0.35;
    }
    100% {
      transform: scale(1.7);
      opacity: 0;
    }
  }

  @keyframes waRing {
    0% {
      transform: scale(1);
      opacity: 0.5;
    }
    100% {
      transform: scale(2);
      opacity: 0;
    }
  }

  /* ---- BURBUJA DE MENSAJE ---- */
  .whatsapp-float__bubble {
    position: absolute;
    bottom: calc(100% + 18px);
    right: 0;
    width: 290px;
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    pointer-events: auto;
    z-index: 1;
  }

  .whatsapp-float__bubble-inner {
    background: var(--wa-bubble-bg, #111111);
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.25), 0 6px 16px rgba(0, 0, 0, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(12px);
  }

  /* Header de la burbuja */
  .whatsapp-float__bubble-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 18px;
    background: linear-gradient(135deg, #075e54 0%, #128c7e 60%, #25d366 100%);
    position: relative;
    overflow: hidden;
  }

  /* Sutil brillo en el header */
  .whatsapp-float__bubble-header::after {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 60%;
    height: 200%;
    background: linear-gradient(135deg, transparent 30%, rgba(255, 255, 255, 0.08) 50%, transparent 70%);
    transform: rotate(25deg);
    pointer-events: none;
  }

  .whatsapp-float__bubble-avatar {
    width: 40px;
    height: 40px;
    min-width: 40px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(6px);
    border: 1px solid rgba(255, 255, 255, 0.12);
  }

  .whatsapp-float__bubble-info {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .whatsapp-float__bubble-name {
    font-size: 13.5px;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-family: var(--font-family-1, 'Barlow Condensed', sans-serif);
  }

  .whatsapp-float__bubble-status {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    color: rgba(255, 255, 255, 0.85);
    font-weight: 400;
  }

  .whatsapp-float__status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #4ade80;
    box-shadow: 0 0 8px rgba(74, 222, 128, 0.7);
    animation: waDotPulse 2s ease-in-out infinite;
  }

  @keyframes waDotPulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.4;
    }
  }

  /* Body de la burbuja */
  .whatsapp-float__bubble-body {
    padding: 16px 18px;
    background: var(--wa-bubble-bg, #111111);
  }

  .whatsapp-float__bubble-text {
    margin: 0;
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--wa-bubble-text, #e0e0e0);
    font-weight: 400;
  }

  /* Botón CTA */
  .whatsapp-float__cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 13px 18px;
    background: linear-gradient(135deg, var(--wa-accent, #25d366), #128c7e);
    color: #ffffff;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: filter 0.3s ease, transform 0.2s ease;
    font-family: var(--font-family-1, 'Barlow Condensed', sans-serif);
    position: relative;
    overflow: hidden;
  }

  .whatsapp-float__cta:hover {
    filter: brightness(1.1);
  }

  .whatsapp-float__cta:active {
    transform: scale(0.98);
  }

  .whatsapp-float__cta svg {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  /* Shiny sweep en el CTA */
  .whatsapp-float__cta::after {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 60%;
    height: 100%;
    background: linear-gradient(
      to right,
      rgba(255, 255, 255, 0) 0%,
      rgba(255, 255, 255, 0.25) 50%,
      rgba(255, 255, 255, 0) 100%
    );
    transform: skewX(-20deg);
    animation: waCtaShine 4s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes waCtaShine {
    0% {
      left: -100%;
    }
    30% {
      left: 150%;
    }
    100% {
      left: 150%;
    }
  }

  /* Flechita de la burbuja */
  .whatsapp-float__bubble-inner::after {
    content: '';
    position: absolute;
    bottom: -8px;
    right: 24px;
    width: 16px;
    height: 16px;
    background: var(--wa-bubble-bg, #111111);
    transform: rotate(45deg);
    border-radius: 0 0 4px 0;
    box-shadow: 4px 4px 8px rgba(0, 0, 0, 0.08);
  }

  /* ---- MODO HOVER ---- */
  .whatsapp-float--hover-mode .whatsapp-float__bubble {
    opacity: 0;
    visibility: hidden;
    transform: translateY(16px) scale(0.95);
    pointer-events: none;
  }

  .whatsapp-float--hover-mode:hover .whatsapp-float__bubble {
    opacity: 1;
    visibility: visible;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  /* Animación de entrada al cargar la página */
  @keyframes waFloatIn {
    from {
      opacity: 0;
      transform: scale(0.5) translateY(30px);
    }
    to {
      opacity: 1;
