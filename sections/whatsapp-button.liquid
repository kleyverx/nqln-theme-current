              </svg>
            </div>
            <div class="whatsapp-float__bubble-info">
              <span class="whatsapp-float__bubble-name">{{ section.settings.agent_name }}</span>
              <span class="whatsapp-float__bubble-status">
                <span class="whatsapp-float__status-dot"></span>
                {{ section.settings.status_text }}
              </span>
            </div>
          </div>
          <div class="whatsapp-float__bubble-body">
            <p class="whatsapp-float__bubble-text">{{ section.settings.bubble_text }}</p>
          </div>
          <a
            href="https://api.whatsapp.com/send/?phone={{ phone_number }}&text={{ default_message }}"
            class="whatsapp-float__cta"
            target="_blank"
            rel="noopener"
            aria-label="{{ section.settings.bubble_button_text }}"
          >
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
            </svg>
            {{ section.settings.bubble_button_text }}
          </a>
        </div>
      </div>
    {% endunless %}

    <button
      class="whatsapp-float__btn"
      aria-label="{{ section.settings.button_aria_label }}"
      onclick="window.open('https://api.whatsapp.com/send/?phone={{ phone_number }}&text={{ button_message }}', '_blank')"
      type="button"
    >
      <span class="whatsapp-float__btn-ring"></span>
      <span class="whatsapp-float__btn-pulse"></span>
      <svg viewBox="-1.5 0 259 259" xmlns="http://www.w3.org/2000/svg" fill="#FFFFFF" class="whatsapp-float__btn-icon">
        <path d="M67.6631045,221.823373 L71.8484512,223.916047 C89.2873956,234.379413 108.819013,239.262318 128.350631,239.262318 L128.350631,239.262318 C189.735716,239.262318 239.959876,189.038158 239.959876,127.653073 C239.959876,98.3556467 228.101393,69.7557778 207.17466,48.8290445 C186.247927,27.9023111 158.345616,16.0438289 128.350631,16.0438289 C66.9655467,16.0438289 16.7413867,66.2679889 17.4389445,128.350631 C17.4389445,149.277365 23.7169645,169.50654 34.1803311,186.945485 L36.9705622,191.130831 L25.8096378,232.28674 L67.6631045,221.823373 Z" fill="#00E676"></path>
