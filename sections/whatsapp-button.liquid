{% assign phone_number = section.settings.phone_number | remove: '+' | remove: ' ' | remove: '-' %}
{% assign default_message = section.settings.default_message | url_encode %}
{% assign button_message = section.settings.button_message | url_encode %}

<div
  class="whatsapp-float-container"
  style="
    --wa-accent: {{ section.settings.button_background_color }};
    --wa-accent-hover: {{ section.settings.button_hover_color }};
    --wa-bubble-bg: {{ section.settings.bubble_background_color }};
    --wa-bubble-text: {{ section.settings.bubble_text_color }};
  "
>
  <div class="whatsapp-float {% if section.settings.bubble_display == 'hover' %}whatsapp-float--hover-mode{% endif %}">
    {% unless section.settings.bubble_display == 'hidden' %}
      <div class="whatsapp-float__bubble">
        <div class="whatsapp-float__bubble-inner">
          <div class="whatsapp-float__bubble-header">
            <div class="whatsapp-float__bubble-avatar">
              <svg viewBox="-1.5 0 259 259" xmlns="http://www.w3.org/2000/svg" fill="#FFFFFF" width="22" height="22">
